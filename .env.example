# Telegram Bot Token — lấy từ @BotFather
TG_TOKEN=1234567890:AAExxxxxxxxxxxxxxxxxxxxx

# Telegram Forum Group ID (số âm, ví dụ: -1001234567890)
# Bot phải là admin của group này, và group phải bật Topics
TG_GROUP_ID=-1001234567890

# Đường dẫn tới file credentials Zalo
ZALO_CREDENTIALS_PATH=./credentials.json

# Thư mục lưu dữ liệu persistent
DATA_DIR=./data
